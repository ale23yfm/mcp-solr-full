putenv('SOLR_HOST=YOUR_HOST');
putenv('SOLR_PORT=8983');
putenv('SOLR_USER=YOUR_USERNAME');
putenv('SOLR_PASS=YOUR_PASSWORD');
putenv('SOLR_SCHEME=http');
